{
  "manifest_version": 3,
  "name": "AutoPause",
  "version": "0.1.0",
  "description": "Pauses your selected music player when another Safari tab starts playing HTML media, then resumes it after the other audio stops.",
  "permissions": [
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "https://music.youtube.com/*",
    "https://open.spotify.com/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "AutoPause",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://music.youtube.com/*",
        "https://open.spotify.com/*"
      ],
      "js": [
        "player-controller.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "<all_urls>"
      ],
      "exclude_matches": [
        "https://music.youtube.com/*",
        "https://open.spotify.com/*"
      ],
      "js": [
        "media-observer.js"
      ],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "icons/icon.svg"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
